{
  "hosting": [
    {
      "target": "app",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "/vault/write",
          "function": { "functionId": "vaultWrite", "region": "us-central1" }
        },
        {
          "source": "/link/lookup",
          "function": { "functionId": "linkLookup", "region": "us-central1" }
        },
        {
          "source": "/agent/capability",
          "function": { "functionId": "agentCapabilityPoll", "region": "us-central1" }
        },
        {
          "source": "/agent/request",
          "function": { "functionId": "agentRequestRelay", "region": "us-central1" }
        },
        {
          "source": "/credential/poll",
          "function": { "functionId": "credentialPoll", "region": "us-central1" }
        },
        {
          "source": "/credential/offer",
          "function": { "functionId": "credentialOfferRelay", "region": "us-central1" }
        },
        {
          "source": "/push/dispatch",
          "function": { "functionId": "pushDispatch", "region": "us-central1" }
        },
        {
          "source": "/push/register",
          "function": { "functionId": "pushChannelRegister", "region": "us-central1" }
        },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Permissions-Policy",
              "value": "camera=(self), microphone=(), geolocation=(), payment=()"
            },
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            {
              "key": "Strict-Transport-Security",
              "value": "max-age=31536000; includeSubDomains; preload"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "/index.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "/",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "/manifest.json",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "/sw.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "/sw-init.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        }
      ]
    },
    {
      "target": "landing",
      "public": "landing",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            {
              "key": "Strict-Transport-Security",
              "value": "max-age=31536000; includeSubDomains; preload"
            }
          ]
        }
      ]
    },
    {
      "target": "redirect",
      "public": "redirect-xyz",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [{ "source": "**", "destination": "https://kunji.cc", "type": 301 }]
    },
    {
      "target": "issuer",
      "public": "issuer-public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "/.well-known/openid-credential-issuer",
          "function": { "functionId": "issuerOidcMetadata", "region": "us-central1" }
        },
        {
          "source": "/.well-known/oauth-authorization-server",
          "function": { "functionId": "issuerOauthMetadata", "region": "us-central1" }
        },
        {
          "source": "/.well-known/kunji-issuer.json",
          "function": { "functionId": "issuerKeys", "region": "us-central1" }
        },
        {
          "source": "/idv/start",
          "function": { "functionId": "issuerIdvStart", "region": "us-central1" }
        },
        {
          "source": "/idv/webhook",
          "function": { "functionId": "issuerIdvWebhook", "region": "us-central1" }
        },
        {
          "source": "/idv/status",
          "function": { "functionId": "issuerIdvStatus", "region": "us-central1" }
        },
        {
          "source": "/credential-offer",
          "function": { "functionId": "issuerOffer", "region": "us-central1" }
        },
        {
          "source": "/token",
          "function": { "functionId": "issuerTokenEndpoint", "region": "us-central1" }
        },
        {
          "source": "/credential",
          "function": { "functionId": "issuerCredentialEndpoint", "region": "us-central1" }
        },
        {
          "source": "/status/1",
          "function": { "functionId": "issuerStatusEndpoint", "region": "us-central1" }
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Permissions-Policy",
              "value": "camera=(), microphone=(), geolocation=(), payment=()"
            },
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            {
              "key": "Strict-Transport-Security",
              "value": "max-age=31536000; includeSubDomains; preload"
            },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://kunji.cc; connect-src 'self'; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
            }
          ]
        }
      ]
    },
    {
      "target": "admin",
      "public": "admin/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "/api/**",
          "function": { "functionId": "issuerAdminApi", "region": "us-central1" }
        },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Permissions-Policy",
              "value": "camera=(), microphone=(), geolocation=(), payment=()"
            },
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            {
              "key": "Strict-Transport-Security",
              "value": "max-age=31536000; includeSubDomains; preload"
            },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://kunji.cc https://*.googleusercontent.com; connect-src 'self' https://issuer-kunji-cc.web.app https://identitytoolkit.googleapis.com https://securetoken.googleapis.com; font-src 'self' data:; frame-src https://kunji-cc.firebaseapp.com https://accounts.google.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
            }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "app"
    },
    {
      "source": "issuer-functions",
      "codebase": "issuer"
    }
  ]
}
