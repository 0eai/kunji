# Non-secret config for the issuer Functions (copy to issuer-functions/.env; 2nd-gen Functions load it).
# The only SECRET is the signing key, set via `firebase functions:secrets:set KUNJI_ISSUER_SIGNING_KEY`.
ISSUER_ORIGIN=https://issuer-kunji-cc.web.app
# STORAGE_BUCKET=kunji-cc.firebasestorage.app   # default in code; override only if the bucket differs
# ISSUER_OPEN_MINT=true                          # DEV ONLY — mint without a verification. Leave unset in prod.
