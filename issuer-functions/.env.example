# Non-secret config for the issuer Functions (copy to issuer-functions/.env; 2nd-gen Functions load it).
# SECRETS are NOT here — set via `firebase functions:secrets:set`:
#   KUNJI_ISSUER_SIGNING_KEY, PERSONA_API_KEY, PERSONA_WEBHOOK_SECRET
ISSUER_ORIGIN=https://issuer-kunji-cc.web.app
# ISSUER_OPEN_MINT=true               # TEST ONLY — open minting with no proofing. Leave unset in production.
PERSONA_INQUIRY_TEMPLATE_ID=          # itmpl_… (a "Government ID + Selfie" template in the Persona dashboard)
# PERSONA_VERSION=                    # optional — pin the Persona API version (else the account default)
