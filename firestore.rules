rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A user can read/write only their own per-device data: vault credentials + activity log.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Apps list, keyed by a master-key-derived vaultId. READS are gated by knowing the
    // high-entropy vaultId (and all stored metadata is encrypted with the master key).
    // WRITES go through the signed-writes Cloud Function (Admin SDK, which bypasses
    // these rules) — direct client writes are denied, so a leaked vaultId alone cannot
    // tamper with the vault.
    match /vaults/{vaultId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Device-linking relay (issuer → consumer). Two-round, write-once:
    //   create (issuer A): publishes A's ephemeral key + lookup code; no peer key/secret.
    //   update#1 (consumer B): pending -> keyset, adds pubB, pubA immutable, still no secret.
    //   update#2 (issuer A): keyset -> sent, adds encryptedMasterKey, both keys immutable.
    // Each transition happens at most once and neither ephemeral key can be swapped, so a
    // relay can't substitute keys or re-deposit. The shared-secret SAS (confirmed on both
    // devices before A deposits) is the user-verifiable backstop against substitution.
    match /linkSessions/{linkId} {
      allow get: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.status == 'pending'
        && 'pubA' in request.resource.data
        && !('pubB' in request.resource.data)
        && !('encryptedMasterKey' in request.resource.data);
      // B publishes its ephemeral key (pending -> keyset).
      allow update: if request.auth != null
        && resource.data.status == 'pending'
        && request.resource.data.status == 'keyset'
        && request.resource.data.pubA == resource.data.pubA
        && 'pubB' in request.resource.data
        && !('encryptedMasterKey' in request.resource.data);
      // A deposits the encrypted master key (keyset -> sent).
      allow update: if request.auth != null
        && resource.data.status == 'keyset'
        && request.resource.data.status == 'sent'
        && request.resource.data.pubA == resource.data.pubA
        && request.resource.data.pubB == resource.data.pubB;
    }

    // Relying-party login sessions (examples/kunji-login-demo). Server-only via Cloud
    // Functions (Admin); clients poll the getSessionStatus function and never read the
    // doc directly, so code/challenge/callbackUrl are not exposed.
    match /loginSessions/{sessionId} {
      allow read, write: if false;
    }

    // Agent capability relay. The wallet (authed) deposits the ECDH-encrypted capability in a
    // single write-once create; the (unauthenticated) MCP bridge reads it ONLY via the
    // agentCapabilityPoll function (Admin), so no client read here. The doc holds only
    // ciphertext + the wallet's ephemeral pub + audience — never the master key or plaintext.
    match /agentSessions/{sessionId} {
      allow create: if request.auth != null
        && 'walletPubE' in request.resource.data
        && 'encryptedCapability' in request.resource.data
        && 'audience' in request.resource.data
        && 'expiresAt' in request.resource.data;
      allow read, update, delete: if false;
    }

    // Capability revocations. Public-readable so any relying party can check a capability's
    // jti; write-once create by an authed wallet. Forgery is a non-issue: the RP verifies `sig`
    // (over "kunji-revoke-v1:{jti}") against the CAPABILITY'S OWN key, so a revocation not signed
    // by the issuing per-app key is ignored. Carries no secret — only {jti, sig, revokedAt}.
    match /revocations/{jti} {
      allow read: if true;
      allow create: if request.auth != null
        && 'jti' in request.resource.data
        && 'sig' in request.resource.data;
      allow update, delete: if false;
    }

    // Agent authorization-request relay (OTP / QR). Fully function-mediated, both ways:
    // the unauthenticated agent POSTs its request via agentRequestRelay (Admin) and the wallet
    // GETs it by 6-digit code through the same function — neither touches the doc directly. The
    // stored request is not secret (pubkeys + scope, no master key); the minted capability is still
    // ECDH-encrypted to transportPub and bound to agentPub, so a guessed code authorizes nothing.
    match /agentRequests/{code} {
      allow read, write: if false;
    }

    // Verified-credential issuance relay. Function-mediated both ways: the (unauthenticated) issuer
    // deposits an ECDH-encrypted credential via the agentRequestRelay-style credentialOfferRelay
    // (Admin) and the wallet polls it via credentialPoll (Admin) — neither touches the doc directly.
    // The doc holds only ciphertext + the issuer's ephemeral pub + the issuer id (no master key).
    match /credentialSessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
