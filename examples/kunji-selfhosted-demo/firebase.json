{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/session", "function": { "functionId": "createSession", "region": "us-central1" } },
      { "source": "/kunji/callback", "function": { "functionId": "kunjiCallback", "region": "us-central1" } },
      { "source": "/kunji/status", "function": { "functionId": "getSessionStatus", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'none'; script-src 'self' https://www.gstatic.com https://kunji.cc; connect-src 'self' https://*.googleapis.com; img-src 'self' https: data:; style-src 'unsafe-inline'; frame-ancestors 'none'; base-uri 'none'"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
      }
    ]
  },
  "functions": { "source": "functions", "codebase": "selfhosted" },
  "firestore": { "rules": "firestore.rules" }
}
