{
  "hosting": {
    "site": "kunji-demo",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/session",
        "function": { "functionId": "createSession", "region": "us-central1" }
      },
      {
        "source": "/api/profile",
        "function": { "functionId": "apiProfile", "region": "us-central1" }
      },
      {
        "source": "/kunji/session",
        "function": { "functionId": "lookupSession", "region": "us-central1" }
      },
      {
        "source": "/kunji/status",
        "function": { "functionId": "getSessionStatus", "region": "us-central1" }
      },
      {
        "source": "/kunji/callback",
        "function": { "functionId": "kunjiCallback", "region": "us-central1" }
      },
      {
        "source": "/kunji/agent",
        "function": { "functionId": "kunjiAgent", "region": "us-central1" }
      },
      {
        "source": "/.well-known/openid-credential-issuer",
        "function": { "functionId": "issuerMetadata", "region": "us-central1" }
      },
      {
        "source": "/.well-known/oauth-authorization-server",
        "function": { "functionId": "oauthMetadata", "region": "us-central1" }
      },
      {
        "source": "/.well-known/kunji-issuer.json",
        "function": { "functionId": "issuerWellKnownFn", "region": "us-central1" }
      },
      {
        "source": "/issue",
        "function": { "functionId": "issueCredential", "region": "us-central1" }
      },
      {
        "source": "/.well-known/kunji-verifier.json",
        "function": { "functionId": "verifierWellKnownFn", "region": "us-central1" }
      },
      {
        "source": "/credential-offer",
        "function": { "functionId": "credentialOffer", "region": "us-central1" }
      },
      {
        "source": "/token",
        "function": { "functionId": "issuerToken", "region": "us-central1" }
      },
      {
        "source": "/credential",
        "function": { "functionId": "issuerCredential", "region": "us-central1" }
      },
      {
        "source": "/status/1",
        "function": { "functionId": "issuerStatus", "region": "us-central1" }
      },
      {
        "source": "/oid4vp/request",
        "function": { "functionId": "oid4vpRequest", "region": "us-central1" }
      },
      {
        "source": "/oid4vp/response",
        "function": { "functionId": "oid4vpResponse", "region": "us-central1" }
      },
      {
        "source": "/oid4vp/result",
        "function": { "functionId": "oid4vpResult", "region": "us-central1" }
      },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' https://kunji.cc; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://app.kunji.cc https://kunji-demo.web.app https://us-central1-kunji-cc.cloudfunctions.net; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
      },
      {
        "source": "/",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
      }
    ]
  },
  "functions": { "source": "functions" }
}
