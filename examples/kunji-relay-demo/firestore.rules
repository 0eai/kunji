rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny ALL direct client access. The wallet never touches Firestore — it POSTs to the
    // kunjiCallback Function. Both that Function and the local RP server use the Admin SDK,
    // which bypasses these rules. So the only writes are verified-at-the-edge writes.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
