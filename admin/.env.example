# kunji-cc Firebase web config (PUBLIC values — safe to ship in the bundle). Copy to admin/.env and fill
# from the Firebase console (Project settings → Your apps). The admin SPA uses these only for Google sign-in.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=kunji-cc.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=kunji-cc
VITE_FIREBASE_APP_ID=
# The issuer origin whose public .well-known the Keys view reads. Flip to https://issuer.kunji.cc once DNS is live.
VITE_ISSUER_ORIGIN=https://issuer-kunji-cc.web.app
